# Frontend environment variables
# Copy this file to .env.local and replace placeholder values.
# Keep .env.local out of version control.

# Supabase configuration (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay frontend public key (Dashboard -> API Keys)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Backend-only secrets (set in Supabase Dashboard -> Edge Functions)
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_secret_key_from_razorpay
# JWT_SECRET=generate_a_strong_random_secret